# SAP SIM — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored; never commit secrets.
#
# ── LLM Gateway ──────────────────────────────────────────────────────────────

# Base URL for the LiteLLM / OpenAI-compatible gateway (no trailing slash)
LLM_BASE_URL=http://localhost:4000

# API key for the LiteLLM gateway
LLM_API_KEY=changeme

# ── Frontend ──────────────────────────────────────────────────────────────────

# URL the *browser* uses to reach the backend API.
# For carlab local deployment this is the Traefik-routed backend domain.
# ⚠ This is baked into the Next.js bundle at build time (NEXT_PUBLIC_* var).
#    If you change this, you must rebuild the frontend image.
NEXT_PUBLIC_API_URL=http://sapsim-api.carlab.local/api

# ── Backend ───────────────────────────────────────────────────────────────────

# Path to the SQLite database inside the container.
# The docker-compose volume mount maps ./data on the host to /app/data in the
# container. Override only if you change the volume configuration.
DB_PATH=/app/data/sapsim.db

# Extra CORS origins to allow (comma-separated).
# Useful when adding a public domain or Cloudflare Tunnel URL.
# Example: CORS_ORIGINS=https://sapsim.example.com,https://sapsim-api.example.com
CORS_ORIGINS=

# Python log level: debug | info | warning | error
LOG_LEVEL=info
